{
  "socket_path": "/run/killswitch/admin.sock",
  "notify_interface_changes": true,
  "notify_global_allow_all": true,
  "tray_enabled": true,
  "network_check": {
    "period": "300s",
    "url": "http://connectivity-check.ubuntu.com/",
    "status": 204,
    "header": "online",
    "notify": true,
    "captive_portal": {
      "env": {
        "MY_TMP_DIR": "{{.Tmp}}"
      },
      "cmd": [
        "chromium",
        "--proxy-server={{.ProxyAddr}}",
        "--user-data-dir={{.Tmp}}",
        "--no-first-run",
        "--password-store=basic",
        "--disable-features=DbusSecretPorta",
        "{{.Portal}}"
      ]
    }
  }
}
