    "198.51.100.10",
    "203.0.113.20"
  ],
  "allowed_v6_hosts": [
    "2001:db8::10",
    "2001:db8::20"
  ],
  "allowed_v4_hostports": [
    "tcp/198.51.100.10:443",
    "udp/203.0.113.20:51820"
  ],
  "allowed_v6_hostports": [
    "tcp/[2001:db8::10]:443",
    "udp/[2001:db8::20]:51820"
  ]
