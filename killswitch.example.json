{
  "interface_types": [
    "device"
  ],
  "interface_names": [
    "eth0",
    "wlan0"
  ],
  "interface_regexps": [
    "^(en|wl|ww)"
  ],
  "allow_all": false,
  "enable_v4": true,
  "enable_v6": true,
  "allowed_marks": [
    "0x42",
    "100"
  ],
